{
    "name": "webfiori/vuetify-core",
    "description": "A base theme which holds basic structure for building Vuetify based themes.",
    "homepage": "https://webfiori.com",
    "support": {
        "issues": "https://github.com/WebFiori/vuetifyCore/issues",
        "source": "https://github.com/WebFiori/vuetifyCore"
    },
    "authors": [
        {
            "name": "Ibrahim BinAlshikh",
            "email": "ibrahim@webfiori.com"
        }
    ],
    "require": {
        "webfiori/framework": "v3.0.0-RC0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "friendsofphp/php-cs-fixer": "^3.86"
    },
    "autoload": {
        "psr-4": {
            "Themes\\": "Themes/"
        }
    },
    "keywords": [
        "framework",
        "webfiori",
        "php",
        "API",
        "Web APIs",
        "Themes",
        "Vuetify",
        "Vue"
    ],
    "license": "MIT",
    "scripts": {
        "test": "vendor/bin/phpunit -c tests/phpunit.xml",
        "test10": "vendor/bin/phpunit -c tests/phpunit10.xml",
        "fix-cs": "vendor/bin/php-cs-fixer fix --config=php_cs.php.dist"
    }
}
